{
  "name": "@dba/admin",
  "version": "0.0.1",
  "private": true,
  "packageManager": "bun@1.3.13",
  "type": "module",
  "engines": {
    "bun": ">=1.1.0",
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev --port 3100 --webpack",
    "build": "bun run build:next",
    "build:next": "node ../../scripts/require-clerk-build-env.mjs && NODE_OPTIONS=\"--max-old-space-size=4096\" next build",
    "build:worker": "node ../../scripts/require-clerk-build-env.mjs && NODE_OPTIONS=\"--max-old-space-size=4096\" opennextjs-cloudflare build",
    "preview": "bun run build:worker && wrangler dev",
    "deploy": "node ../../scripts/require-clerk-build-env.mjs && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "start": "next start --port 3100",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.3.0",
    "@dba/api": "workspace:*",
    "@dba/shared": "workspace:*",
    "@elysiajs/eden": "^1.4.9",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.14.0",
    "motion": "^12.0.0",
    "next": "16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260503.1",
    "@opennextjs/cloudflare": "^1.19.5",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "wrangler": "^4.87.0"
  }
}
