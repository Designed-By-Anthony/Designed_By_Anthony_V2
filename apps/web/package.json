{
  "name": "@dba/web",
  "version": "0.0.1",
  "private": true,
  "packageManager": "bun@1.3.13",
  "type": "module",
  "engines": {
    "bun": ">=1.1.0",
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev . --webpack",
    "build": "bun run build:next",
    "build:next": "NODE_OPTIONS=\"--max-old-space-size=4096\" next build",
    "build:worker": "NODE_OPTIONS=\"--max-old-space-size=4096\" opennextjs-cloudflare build",
    "preview": "bun run build:worker && wrangler dev",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "icons:generate": "node scripts/generate-brand-icons.mjs"
  },
  "dependencies": {
    "@dba/shared": "workspace:*",
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/outfit": "^5.2.8",
    "@fontsource/abril-fatface": "^5.2.7",
    "@marsidev/react-turnstile": "^1.5.1",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.38.0",
    "gsap": "^3.15.0",
    "next": "16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "sharp": "^0.34.5",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.5",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^24",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.0",
    "png-to-ico": "^3.0.1",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "wrangler": "^4.87.0"
  },
  "browserslist": [
    "chrome >= 91",
    "firefox >= 90",
    "safari >= 15",
    "edge >= 91",
    "not dead"
  ]
}
