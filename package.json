{
  "name": "dba-monorepo",
  "version": "0.0.1",
  "private": true,
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "turbo run dev --filter=@dba/web",
    "dev:admin": "turbo run dev --filter=@dba/admin",
    "dev:api": "turbo run dev --filter=@dba/api",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check . --write --unsafe",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "test:e2e": "playwright test apps/web/tests/e2e",
    "test:security": "playwright test apps/api/tests/security",
    "test:chaos": "playwright test apps/web/tests/e2e/chaos-suite.spec.ts",
    "test": "playwright test",
    "test:ui": "playwright show-report",
    "test:install": "playwright install"
  },
  "engines": {
    "node": ">=22"
  },
  "volta": {
    "node": "22.22.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@playwright/test": "^1.59.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "turbo": "^2.9.8"
  }
}
