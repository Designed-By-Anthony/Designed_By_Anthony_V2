{
  "name": "dba-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-02",
  "compatibility_flags": ["nodejs_compat"],
  "routes": [
    {
      "pattern": "api.designedbyanthony.com",
      "custom_domain": true
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "dba-ledger",
      "database_id": "961ce211-2843-4ed7-a609-9ab224f7eb8a"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "AUDIT_REPORTS_KV",
      "id": "48827a794a8b4ccc8b0dc3dbca8c80ec"
    }
  ],
  "r2_buckets": [
    {
      "binding": "PDF_STORAGE",
      "bucket_name": "dba-pdf-archive"
    }
  ],
  "queues": {
    "producers": [
      {
        "queue": "pdf-gen-queue",
        "binding": "PDF_GEN_QUEUE"
      }
    ],
    "consumers": [
      {
        "queue": "pdf-gen-queue",
        "max_batch_size": 1,
        "max_retries": 5
      }
    ]
  },
  "vars": {
    "CF_PAGES_BRANCH": "main"
  },
  "env": {
    "preview": {
      "name": "dba-api-preview",
      "routes": [
        {
          "pattern": "preview.api.designedbyanthony.com",
          "custom_domain": true
        }
      ],
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "dba-preview-db",
          "database_id": "5bb266d2-bc50-4077-a8ef-dc21450b8e1f"
        }
      ],
      "vars": {
        "CF_PAGES_BRANCH": "main"
      }
    }
  }
}
